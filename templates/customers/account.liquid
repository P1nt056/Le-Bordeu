<div class="customer-page container">
  <div class="customer-dashboard">
    <h1 class="section-title">A Minha Conta</h1>
    <p class="customer-logout"><a href="/account/logout" class="btn btn--secondary">Terminar Sessão</a></p>

    <div class="dashboard-grid">
      <div class="dashboard-orders">
        <h2>Histórico de Encomendas</h2>

        {% paginate customer.orders by 20 %}
          {% if customer.orders.size == 0 %}
            <p>Ainda não realizou nenhuma encomenda.</p>
          {% else %}
            <table class="orders-table">
              <thead>
                <tr>
                  <th>Encomenda</th>
                  <th>Data</th>
                  <th>Pagamento</th>
                  <th>Envio</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                {% for order in customer.orders %}
                  <tr>
                    <td><a href="{{ order.customer_url }}" class="order-link">{{ order.name }}</a></td>
                    <td>{{ order.created_at | time_tag: format: 'date' }}</td>
                    <td>{{ order.financial_status_label }}</td>
                    <td>{{ order.fulfillment_status_label }}</td>
                    <td>{{ order.total_price | money }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
            {{ paginate | default_pagination }}
          {% endif %}
        {% endpaginate %}
      </div>

      <div class="dashboard-details">
        <h2>Detalhes da Conta</h2>
        <p class="customer-name"><strong>{{ customer.name }}</strong></p>
        <p class="customer-email">{{ customer.email }}</p>
        
        <div class="customer-address">
          {{ customer.default_address | format_address }}
        </div>
        
        <p><a href="/account/addresses" class="btn btn--secondary" style="font-size: 11px; padding: 10px 18px;">Gerir Endereços ({{ customer.addresses_count }})</a></p>
      </div>
    </div>
  </div>
</div>
