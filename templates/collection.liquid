<div class="collection-page container">
  {% assign is_new_arrivals = false %}
  {% if collection.handle == 'new' %}
    {% assign is_new_arrivals = true %}
  {% elsif collection.handle == 'all' and request.params.sort_by == 'created-descending' %}
    {% assign is_new_arrivals = true %}
  {% elsif collection.handle == 'all' and collection.sort_by == 'created-descending' %}
    {% assign is_new_arrivals = true %}
  {% endif %}
  {% assign is_sale = false %}
  {% if collection.handle == 'promocoes' %}
    {% assign is_sale = true %}
  {% endif %}
  {% assign products_per_page = 12 %}

  <h1 class="section-title">
    {% if is_new_arrivals %}
      <span data-i18n="col_new">Novidades</span>
    {% elsif is_sale %}
      <span data-i18n="col_sale">Promoções Especiais</span>
    {% else %}
      <span data-i18n="col_title_{{ collection.title | handleize }}">{{ collection.title }}</span>
    {% endif %}
  </h1>

  {% paginate collection.products by products_per_page %}
    {% if collection.products.size == 0 %}
      <div class="collection-empty">
        <p data-i18n="col_empty">Esta coleção não contém produtos de momento.</p>
        <a href="/" class="btn btn--primary" data-i18n="col_home">Voltar ao Início</a>
      </div>
    {% else %}
      <p class="collection-count">
        {% if is_new_arrivals %}
          <span data-i18n="col_latest">Os 12 produtos mais recentes da loja</span>
        {% else %}
          <span data-i18n-count="{{ collection.products_count }}" data-i18n="col_found">{{ collection.products_count }} produtos encontrados</span>
        {% endif %}
      </p>

      {% if collection.handle == 'all' and is_new_arrivals == false %}
        <button type="button" class="btn btn--secondary mobile-filters-trigger" id="MobileFiltersTrigger" data-i18n="col_filters_btn">Filtrar Produtos</button>
        <div class="collection-layout">
          <aside class="collection-sidebar" id="CollectionSidebar">
            <div class="filters-header">
              <h3 class="filters-title" data-i18n="col_filters">Filtros</h3>
              <div class="filters-header-actions">
                <button type="button" class="filters-clear" id="ClearFiltersBtn" data-i18n="col_clear">Limpar filtros</button>
                <button type="button" class="mobile-filters-close" id="MobileFiltersClose" aria-label="Fechar">&times;</button>
              </div>
            </div>
            <form class="filter-form" id="CollectionFiltersForm">
              <details class="filter-group">
                <summary class="filter-group-summary" data-i18n="col_gender">Género<span class="icon-accordion"></span></summary>
                <div class="filter-group-display">
                  <ul class="filter-list">
                    {% assign gender_options = "Homem, Mulher" | split: ", " %}
                    {% for option in gender_options %}
                      <li class="filter-list-item">
                        <label class="filter-label">
                          {% assign tag_handle = option | handleize %}
                          <input type="checkbox" class="custom-tag-checkbox" data-group="genero" value="{{ tag_handle }}" {% if current_tags contains tag_handle or current_tags contains option %}checked{% endif %}>
                          <span class="filter-text" data-i18n="flt_{{ option }}">{{ option }}</span>
                        </label>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>

              <details class="filter-group">
                <summary class="filter-group-summary" data-i18n="col_type">Tipo<span class="icon-accordion"></span></summary>
                <div class="filter-group-display">
                  <ul class="filter-list">
                    {% assign type_options = "T-shirts, Macacões, Vestidos, Relógios, Bijuteria, Calçado, Calças, Malas, Top's" | split: ", " %}
                    {% for option in type_options %}
                      <li class="filter-list-item">
                        <label class="filter-label">
                          {% assign tag_handle = option | handleize %}
                          <input type="checkbox" class="custom-tag-checkbox" data-group="tipo" value="{{ tag_handle }}" {% if current_tags contains tag_handle or current_tags contains option %}checked{% endif %}>
                          <span class="filter-text" data-i18n="flt_{{ option }}">{{ option }}</span>
                        </label>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>

              <details class="filter-group" id="subtipo-bijuteria" style="display: none;">
                <summary class="filter-group-summary" data-i18n="col_cat_jewelry">Categoria (Bijuteria)<span class="icon-accordion"></span></summary>
                <div class="filter-group-display">
                  <ul class="filter-list filter-list--scrollable">
                    {% assign sub_bijuteria = "Colares, Brincos, Pulseiras, Anéis" | split: ", " %}
                    {% for option in sub_bijuteria %}
                      <li class="filter-list-item">
                        <label class="filter-label">
                          {% assign tag_handle = option | handleize %}
                          <input type="checkbox" class="custom-tag-checkbox" data-group="subtipo" value="{{ tag_handle }}" {% if current_tags contains tag_handle or current_tags contains option %}checked{% endif %}>
                          <span class="filter-text" data-i18n="flt_{{ option }}">{{ option }}</span>
                        </label>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>

              <details class="filter-group" id="subtipo-calcado" style="display: none;">
                <summary class="filter-group-summary" data-i18n="col_cat_shoes">Categoria (Calçado)<span class="icon-accordion"></span></summary>
                <div class="filter-group-display">
                  <ul class="filter-list filter-list--scrollable">
                    {% assign sub_calcado = "Botas, Sapatos de tacão" | split: ", " %}
                    {% for option in sub_calcado %}
                      <li class="filter-list-item">
                        <label class="filter-label">
                          {% assign tag_handle = option | handleize %}
                          <input type="checkbox" class="custom-tag-checkbox" data-group="subtipo" value="{{ tag_handle }}" {% if current_tags contains tag_handle or current_tags contains option %}checked{% endif %}>
                          <span class="filter-text">{{ option }}</span>
                        </label>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>

              {%- for filter in collection.filters -%}
                {%- if filter.param_name == 'filter.v.availability' -%}
                  {%- continue -%}
                {%- endif -%}
                <details class="filter-group">
                  <summary class="filter-group-summary" data-i18n="flt_{{ filter.label | handleize }}">{{ filter.label }}<span class="icon-accordion"></span></summary>
                  <div class="filter-group-display">
                    {%- case filter.type -%}
                      {%- when 'boolean' or 'list' -%}
                        <ul class="filter-list">
                          {%- for filter_value in filter.values -%}
                            <li class="filter-list-item">
                              <label for="Filter-{{ filter.param_name }}-{{ forloop.index }}" class="filter-label{% if filter_value.count == 0 and filter_value.active == false %} filter-label--disabled{% endif %}">
                                <input type="checkbox"
                                  name="{{ filter_value.param_name }}"
                                  value="{{ filter_value.value }}"
                                  id="Filter-{{ filter.param_name }}-{{ forloop.index }}"
                                  {% if filter_value.active -%}checked{%- endif %}
                                  {% if filter_value.count == 0 and filter_value.active == false -%}disabled{%- endif %}
                                >
                                <span class="filter-checkbox"></span>
                                {{ filter_value.label }} ({{ filter_value.count }})
                              </label>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- when 'price_range' -%}
                        <div class="filter-price">
                          <div class="filter-price__field">
                            <span class="filter-price__currency">{{ cart.currency.symbol }}</span>
                            <input name="{{ filter.min_value.param_name }}"
                              id="Filter-{{ filter.min_value.param_name }}"
                              {% if filter.min_value.value -%}
                                value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                              {%- endif %}
                              type="number"
                              placeholder="0"
                              min="0"
                              max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            >
                          </div>
                          <span class="filter-price__separator">-</span>
                          <div class="filter-price__field">
                            <span class="filter-price__currency">{{ cart.currency.symbol }}</span>
                            <input name="{{ filter.max_value.param_name }}"
                              id="Filter-{{ filter.max_value.param_name }}"
                              {% if filter.max_value.value -%}
                                value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                              {%- endif %}
                              type="number"
                              placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                              min="0"
                              max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            >
                          </div>
                        </div>
                    {%- endcase -%}
                  </div>
                </details>
              {%- endfor -%}
            </form>
            <button type="button" class="btn btn--primary mobile-filters-apply" id="MobileFiltersApply" data-i18n="col_apply">Aplicar Filtros</button>
          </aside>
          <div class="collection-main">
      {% endif %}

      <div class="products-grid">
        {% for product in collection.products %}
          <div class="product-card">
            <a href="{{ product.url }}">
              <div class="product-card__media">
                {% if product.compare_at_price_max > product.price %}
                  <span class="tag tag--sale" data-i18n="prod_promo">Promoção</span>
                {% endif %}
                <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" loading="lazy">
                {% if product.images.size > 1 %}
                  <img class="hover-img" src="{{ product.images[1] | img_url: '800x' }}" alt="{{ product.title }}" loading="lazy">
                {% endif %}
              </div>
              <div class="product-card__info">
                <h3>{{ product.title }}</h3>
                <div class="price">
                  {% if product.compare_at_price_max > product.price %}
                    <span class="price--old">{{ product.compare_at_price_max | money }}</span>
                    <span class="price--sale">{{ product.price | money }}</span>
                  {% else %}
                    <span class="price--normal">{{ product.price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
            <a href="{{ product.url }}" class="btn btn--primary btn--buy" style="text-align: center; text-decoration: none;" data-i18n="prod_view">Ver Produto</a>
          </div>
        {% endfor %}
      </div>

      {% if collection.handle == 'all' and is_new_arrivals == false %}
          </div>
        </div>
      {% endif %}

      {% if paginate.pages > 1 and is_new_arrivals == false %}
        <div class="pagination">
          {{ paginate | default_pagination: previous: '« Anterior', next: 'Próximo »' | replace: '« Anterior', '<span data-i18n="pagi_prev">« Anterior</span>' | replace: 'Próximo »', '<span data-i18n="pagi_next">Próximo »</span>' }}
        </div>
      {% endif %}
    {% endif %}
  {% endpaginate %}
</div>
