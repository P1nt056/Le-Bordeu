<header class="site-header">
  <div class="site-header__inner container">
    <div class="logo"><a href="/">Le Bordeu</a></div>
    <nav id="main-navigation" class="main-nav" role="navigation" aria-label="Menu principal">
      <ul>
        <li><a href="/" data-i18n="nav_home">Início</a></li>
        <li>
          {% if collections['new'] != blank %}
            <a href="/collections/new" data-i18n="nav_new">Novidades</a>
          {% else %}
            <a href="/collections/all?sort_by=created-descending" data-i18n="nav_new">Novidades</a>
          {% endif %}
        </li>
        <li><a href="/collections" data-i18n="nav_collections">Coleções</a></li>
        <li><a href="/collections/all" data-i18n="nav_all">Ver Tudo</a></li>
        <li><a href="/collections/promocoes" data-i18n="nav_sale">Promoções</a></li>
      </ul>
    </nav>
    <div class="header-icons">
      <button id="lang-toggle-btn" class="lang-toggle" aria-label="Toggle Language" style="background:none; border:none; color:var(--text-cream); cursor:pointer; font-size:14px; margin-right: 15px;">🇵🇹 PT</button>
      <a href="/search" class="icon icon--search" aria-label="Pesquisar" role="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </a>
      <a href="/account" class="icon icon--account" aria-label="Conta" role="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a href="/cart" class="icon icon--cart" aria-label="Carrinho" role="button" id="cart-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        <span class="cart-count-badge {% if cart.item_count == 0 %}hidden{% endif %}">{{ cart.item_count }}</span>
      </a>
    </div>
    <button class="mobile-menu-btn" aria-label="Abrir menu" aria-expanded="false" aria-controls="main-navigation">☰</button>
  </div>
</header>
