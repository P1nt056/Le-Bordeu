<section class="editorial container" aria-label="Editorial">
  <div class="editorial__media">
    <img src="/images/editorial.jpg" alt="Moda Le Bordeu" loading="lazy">
  </div>
  <div class="editorial__content">
    <h2>Moda pensada para momentos especiais e para o dia a dia.</h2>
    <p>Peças escolhidas para destacar a tua elegância. Luxo nos detalhes, conforto na essência.</p>
    <a href="/pages/about" class="btn btn--secondary">Descobrir a Marca</a>
  </div>
</section>

{% schema %}
{
  "name":"Editorial",
  "settings":[],
  "presets":[{"name":"Editorial"}]
}
{% endschema %}
