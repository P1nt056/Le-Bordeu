<section class="hero" aria-label="Banner principal">
  <div class="hero__media" style="--hero-image: url('{{ 'hero-elegance-couple.png' | asset_url }}');">
    <img src="{{ 'hero-elegance-couple.png' | asset_url }}" alt="Le Bordeu - elegancia editorial" loading="eager" />
  </div>
  <div class="hero__content container">
    <h1 class="hero__title">Eleg&acirc;ncia que se veste. <br>Estilo que se <em>sente</em>.</h1>
    <p class="hero__subtitle">Descobre pe&ccedil;as selecionadas para quem valoriza presen&ccedil;a, conforto e sofistica&ccedil;&atilde;o.</p>
    <div class="hero__actions">
      <a href="/collections/all" class="btn btn--primary">Ver Tudo</a>
      <a href="/collections" class="btn btn--secondary">Ver Cole&ccedil;&otilde;es</a>
    </div>
  </div>
  <div class="hero__overlay"></div>
</section>

