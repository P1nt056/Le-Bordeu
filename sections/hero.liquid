<section class="hero" aria-label="Banner principal">
  <div class="hero__media">
    <!-- Replace with high-res lifestyle image -->
    <img src="/images/hero-placeholder.jpg" alt="Le Bordeu - Elegância" loading="lazy" />
  </div>
  <div class="hero__content container">
    <h1 class="hero__title">Elegância que se veste. Estilo que se sente.</h1>
    <p class="hero__subtitle">Descobre peças selecionadas para quem valoriza presença, conforto e sofisticação.</p>
    <div class="hero__actions">
      <a href="/collections/all" class="btn btn--primary">Comprar Agora</a>
      <a href="/collections" class="btn btn--secondary">Ver Coleções</a>
    </div>
  </div>
  <div class="hero__overlay"></div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [],
  "blocks": [],
  "presets": [{"name":"Hero"}]
}
{% endschema %}
