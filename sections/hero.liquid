<section class="hero" aria-label="Banner principal">
  <div class="hero__media">
    <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=1600&auto=format&fit=crop" alt="Le Bordeu - Elegância" loading="lazy" />
  </div>
  <div class="hero__content container">
    <h1 class="hero__title">Elegância que se veste. <br>Estilo que se <em>sente</em>.</h1>
