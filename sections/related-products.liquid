<section class="related-products container">
  <h3 class="section-title">Produtos recomendados</h3>
  <div class="splide related-splide" aria-label="Produtos recomendados">
    <div class="splide__track">
      <ul class="splide__list">
      {% for product in collections['frontpage'].products limit:6 %}
        <li class="splide__slide">
          <div class="product-card">
            <a href="{{ product.url }}">
              <div class="product-card__media">
                {% if product.compare_at_price_max > product.price %}
                  <span class="tag tag--sale">Promoção</span>
                {% endif %}
                <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" loading="lazy">
                {% if product.images.size > 1 %}
                  <img class="hover-img" src="{{ product.images[1] | img_url: '800x' }}" alt="{{ product.title }}" loading="lazy">
                {% endif %}
              </div>
              <div class="product-card__info">
                <h4>{{ product.title }}</h4>
                <div class="price">
                  {% if product.compare_at_price_max > product.price %}
                    <span class="price--old">{{ product.compare_at_price_max | money }}</span>
                    <span class="price--sale">{{ product.price | money }}</span>
                  {% else %}
                    <span class="price--normal">{{ product.price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
            <a href="{{ product.url }}" class="btn btn--primary btn--buy">Ver Produto</a>
          </div>
        </li>
      {% endfor %}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{"name":"Related products","settings":[],"presets":[{"name":"Related"}]}
{% endschema %}
