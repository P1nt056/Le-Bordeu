<section class="product-page container">
  <div class="product-page__grid">
    <div class="product-page__gallery">
      {% include 'product-gallery' %}
    </div>
    <div class="product-page__details">
      <h1 class="product-title">{{ product.title }}</h1>
      <div class="product-prices">
        {% if product.compare_at_price_max > product.price %}
          <span class="price--old">{{ product.compare_at_price_max | money }}</span>
          <span class="price--sale">{{ product.price | money }}</span>
        {% else %}
          <span class="price--normal">{{ product.price | money }}</span>
        {% endif %}
      </div>

      <form method="post" action="/cart/add" id="add-to-cart-form">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        {% if product.variants.size > 1 %}
          <div class="product-options">
            {% for option in product.options_with_values %}
              <div class="option-header" style="display: flex; justify-content: space-between; align-items: center;">
                <label>{{ option.name }}</label>
                {% if option.name == 'Size' or option.name == 'Tamanho' or option.name == 'size' %}
                  <a href="#" class="size-guide-trigger" style="color: var(--color-gold); font-size: 0.85rem; text-decoration: underline;">Ver tabela de tamanhos</a>
                {% endif %}
              </div>
              <select name="options[{{ option.name }}]" class="single-option-selector" data-index="option{{ forloop.index }}">
                {% for value in option.values %}
                  <option value="{{ value }}">{{ value }}</option>
                {% endfor %}
              </select>
            {% endfor %}
          </div>
        {% endif %}

        <div class="product-actions">
          <button type="submit" class="btn btn--primary">Comprar Agora</button>
          <button type="button" class="btn btn--secondary" id="add-to-cart">Adicionar ao Carrinho</button>
        </div>
      </form>
      
      <script type="application/json" id="ProductJson-{{ product.id }}">
        {{ product | json }}
      </script>

      <div class="size-guide-modal" aria-hidden="true" style="display: none;">
        <div class="size-guide-modal__overlay"></div>
        <div class="size-guide-modal__content">
          <button class="size-guide-modal__close" aria-label="Fechar">✕</button>
          <div class="size-guide-modal__body">
            <!-- Table will be injected here via JS -->
          </div>
        </div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const sizeTriggers = document.querySelectorAll('.size-guide-trigger');
          const sizeModal = document.querySelector('.size-guide-modal');
          
          if (sizeTriggers.length > 0 && sizeModal) {
            const modalBody = sizeModal.querySelector('.size-guide-modal__body');
            const modalClose = sizeModal.querySelector('.size-guide-modal__close');
            const modalOverlay = sizeModal.querySelector('.size-guide-modal__overlay');
            
            const closeSizeModal = (e) => {
              if (e) e.preventDefault();
              sizeModal.style.display = 'none';
              sizeModal.setAttribute('aria-hidden', 'true');
              document.body.style.overflow = '';
            };

            modalClose.addEventListener('click', closeSizeModal);
            modalOverlay.addEventListener('click', closeSizeModal);
            
            document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && sizeModal.style.display !== 'none') closeSizeModal();
            });

            sizeTriggers.forEach(trigger => {
              trigger.addEventListener('click', (e) => {
                e.preventDefault();
                console.log('Size guide trigger clicked');
                
                const descrTable = document.querySelector('.product-description table');
                console.log('Table found:', descrTable);
                
                if (descrTable) {
                  modalBody.innerHTML = '';
                  const clonedTable = descrTable.cloneNode(true);
                  modalBody.appendChild(clonedTable);
                  
                  sizeModal.style.display = 'flex';
                  sizeModal.setAttribute('aria-hidden', 'false');
                  document.body.style.overflow = 'hidden';
                } else {
                  const descBlock = document.querySelector('.product-description');
                  if (descBlock) descBlock.scrollIntoView({ behavior: 'smooth' });
                }
              });
            });
          }
        });
      </script>

      <!-- DEBUG VARIANT STOCK LEVELS:
      {% for v in product.variants %}
        - {{ v.title }}: id={{ v.id }} | available={{ v.available }} | qty={{ v.inventory_quantity }} | option1={{ v.option1 }} | option2={{ v.option2 }}
      {% endfor %}
      -->

      <div class="trust-messages">
        <span>Pagamento 100% seguro</span> • <span>Envio rápido</span> • <span>Trocas simples</span>
      </div>
    </div>
  </div>


  <!-- Detailed Luxury Info Section below the fold -->
  <div class="product-page__info-section">
    <div class="product-page__info-header">
      <span class="product-page__eyebrow">Detalhes do Produto</span>
      <h2 class="info-section-title">Descricao do Produto</h2>
      <p>Construido para acompanhar o ritmo do dia a dia com presenca, conforto e acabamento premium.</p>
    </div>

    <div class="product-page__info-grid">
      <div class="product-page__info-main">

        {% if product.description != blank %}
          {% assign story_title_top = '' %}
          {% assign story_text_top = '' %}
          {% assign story_title_bottom = '' %}
          {% assign story_text_bottom = '' %}
          {% capture specs_html %}{% endcapture %}

          {% assign description_parts = product.description | split: '</p>' %}
          {% for part in description_parts %}
            {% assign part_text = part | strip_html | strip %}
            {% if part_text != blank %}
              {% if part_text contains 'Título cima:' %}
                {% assign story_title_top = part_text | split: 'Título cima:' | last | strip %}
              {% elsif part_text contains 'Titulo cima:' %}
                {% assign story_title_top = part_text | split: 'Titulo cima:' | last | strip %}
              {% elsif part_text contains 'Título baixo:' %}
                {% assign story_title_bottom = part_text | split: 'Título baixo:' | last | strip %}
              {% elsif part_text contains 'Titulo baixo:' %}
                {% assign story_title_bottom = part_text | split: 'Titulo baixo:' | last | strip %}
              {% elsif part_text contains 'Texto cima:' %}
                {% assign story_text_top = part_text | split: 'Texto cima:' | last | strip %}
              {% elsif part_text contains 'Texto baixo:' %}
                {% assign story_text_bottom = part_text | split: 'Texto baixo:' | last | strip %}
              {% elsif part_text contains 'TextoCriado' %}
                {% assign story_text_top = part_text | remove_first: 'Texto' | strip %}
              {% elsif part_text contains 'Texto O' and story_title_bottom != blank %}
                {% assign story_text_bottom = part_text | remove_first: 'Texto' | strip %}
              {% elsif part_text contains 'Texto' and story_text_top == blank %}
                {% assign story_text_top = part_text | remove_first: 'Texto' | strip %}
              {% elsif part_text contains 'Texto' and story_text_bottom == blank %}
                {% assign story_text_bottom = part_text | remove_first: 'Texto' | strip %}
              {% else %}
                {% capture specs_html %}{{ specs_html }}{{ part }}</p>{% endcapture %}
              {% endif %}
            {% endif %}
          {% endfor %}

          {% assign has_story = false %}
          {% if story_title_top != blank or story_text_top != blank or story_title_bottom != blank or story_text_bottom != blank %}
            {% assign has_story = true %}
          {% endif %}

          {% if has_story %}
            <div class="product-story">
              <article class="product-story__row fade-in">
                <div class="product-story__media">
                  {% if product.images[1] != blank %}
                    <img src="{{ product.images[1] | img_url: '1100x' }}" alt="{{ product.title | escape }} em detalhe" loading="lazy">
                  {% elsif product.featured_image != blank %}
                    <img src="{{ product.featured_image | img_url: '1100x' }}" alt="{{ product.title | escape }} em detalhe" loading="lazy">
                  {% endif %}
                </div>
                <div class="product-story__content">
                  <span class="product-story__kicker">Destaque</span>
                  {% if story_title_top != blank %}
                    <h3>{{ story_title_top }}</h3>
                  {% endif %}
                  {% if story_text_top != blank %}
                    <p>{{ story_text_top }}</p>
                  {% endif %}
                </div>
              </article>

              <article class="product-story__row product-story__row--reverse fade-in">
                <div class="product-story__media">
                  {% if product.images[2] != blank %}
                    <img src="{{ product.images[2] | img_url: '1100x' }}" alt="{{ product.title | escape }} em uso" loading="lazy">
                  {% elsif product.featured_image != blank %}
                    <img src="{{ product.featured_image | img_url: '1100x' }}" alt="{{ product.title | escape }} em uso" loading="lazy">
                  {% endif %}
                </div>
                <div class="product-story__content">
                  <span class="product-story__kicker">Detalhe</span>
                  {% if story_title_bottom != blank %}
                    <h3>{{ story_title_bottom }}</h3>
                  {% endif %}
                  {% if story_text_bottom != blank %}
                    <p>{{ story_text_bottom }}</p>
                  {% endif %}
                </div>
              </article>
            </div>
          {% endif %}

          {% if specs_html != blank or has_story == false %}
          <div class="product-description-card{% unless has_story %} product-description-card--standalone{% endunless %} fade-in">
            <div class="product-description-card__media">
              {% if product.images[3] != blank %}
                <img src="{{ product.images[3] | img_url: '1100x' }}" alt="{{ product.title | escape }} caracteristicas" loading="lazy">
              {% elsif product.images[2] != blank %}
                <img src="{{ product.images[2] | img_url: '1100x' }}" alt="{{ product.title | escape }} caracteristicas" loading="lazy">
              {% elsif product.featured_image != blank %}
                <img src="{{ product.featured_image | img_url: '1100x' }}" alt="{{ product.title | escape }} caracteristicas" loading="lazy">
              {% endif %}
            </div>
            <div class="product-description-card__content">
              <span class="product-story__kicker">Especificacoes</span>
              <h3>Caracteristicas completas</h3>
              <div class="product-description">
                {% if specs_html != blank %}
                  {{ specs_html }}
                {% else %}
                  {{ product.description }}
                {% endif %}
              </div>
            </div>
          </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"Product page",
  "settings":[],
  "blocks":[],
  "presets":[{"name":"Product"}]
}
{% endschema %}
