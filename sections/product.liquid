<section class="product-page container">
  {% assign current_variant = product.selected_or_first_available_variant %}
  <div class="product-page__grid">
    <div class="product-page__gallery">
      {% include 'product-gallery' %}
    </div>
    <div class="product-page__details">
      <h1 class="product-title">{{ product.title }}</h1>
      <div id="productAverageRatingWidget" style="display: none; align-items: center; gap: 5px; color: var(--color-gold); font-size: 16px; font-weight: bold; cursor: pointer; margin-bottom: 10px;" title="Ver opiniões" onclick="document.getElementById('productReviews').scrollIntoView({behavior: 'smooth'})">
        <span id="productAverageRatingStars" style="font-size: 18px; letter-spacing: 2px;"></span>
        <span id="productAverageRatingValue" style="margin-left: 5px;"></span>
        <span style="font-size: 12px; font-weight: normal; color: var(--text-muted); margin-left: 5px; text-decoration: underline;" id="productAverageRatingCount"></span>
      </div>
      <div class="product-prices">
        {% if product.compare_at_price_max > product.price %}
          <span class="price--old">{{ product.compare_at_price_max | money }}</span>
          <span class="price--sale">{{ product.price | money }}</span>
        {% else %}
          <span class="price--normal">{{ product.price | money }}</span>
        {% endif %}
      </div>

      <div class="trust-messages" aria-label="Vantagens da loja">
        <span data-i18n="prod_secure"><span class="trust-messages__icon" aria-hidden="true">✓</span>Pagamento 100% seguro</span>
        <span data-i18n="prod_fast"><span class="trust-messages__icon" aria-hidden="true">↗</span>Envio rápido</span>
        <span data-i18n="prod_returns"><span class="trust-messages__icon" aria-hidden="true">↺</span>Trocas simples</span>
      </div>

      <form method="post" action="/cart/add" id="add-to-cart-form">
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% if product.variants.size > 1 %}
          <div class="product-options">
            {% for option in product.options_with_values %}
              {% assign selected_option_value = current_variant.options[forloop.index0] %}
              <div class="option-header" style="display: flex; justify-content: space-between; align-items: center;">
                <label data-i18n="opt_{{ option.name | handleize }}">{{ option.name }}</label>
                {% if option.name == 'Size' or option.name == 'Tamanho' or option.name == 'size' %}
                  <a href="#" class="size-guide-trigger" style="color: var(--color-gold); font-size: 0.85rem; text-decoration: underline;" data-i18n="prod_size">Ver tabela de tamanhos</a>
                {% endif %}
              </div>
              <select name="options[{{ option.name }}]" class="single-option-selector" data-index="option{{ forloop.index }}">
                {% for value in option.values %}
                  <option value="{{ value }}" {% if selected_option_value == value %}selected{% endif %}>{{ value }}</option>
                {% endfor %}
              </select>
            {% endfor %}
          </div>
        {% endif %}

        <div class="product-actions">
          <button type="submit" class="btn btn--primary" data-i18n="prod_buy">Comprar Agora</button>
          <button type="button" class="btn btn--secondary" id="add-to-cart" data-i18n="prod_add">Adicionar ao Carrinho</button>
        </div>
      </form>
      
      <script type="application/json" id="ProductJson-{{ product.id }}">
        {{ product | json }}
      </script>

      <div class="size-guide-modal" aria-hidden="true" style="display: none;">
        <div class="size-guide-modal__overlay"></div>
        <div class="size-guide-modal__content">
          <button class="size-guide-modal__close" aria-label="Fechar">✕</button>
          <div class="size-guide-modal__body">
            <!-- Table will be injected here via JS -->
          </div>
        </div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const sizeTriggers = document.querySelectorAll('.size-guide-trigger');
          const sizeModal = document.querySelector('.size-guide-modal');
          
          if (sizeTriggers.length > 0 && sizeModal) {
            const modalBody = sizeModal.querySelector('.size-guide-modal__body');
            const modalClose = sizeModal.querySelector('.size-guide-modal__close');
            const modalOverlay = sizeModal.querySelector('.size-guide-modal__overlay');
            
            const closeSizeModal = (e) => {
              if (e) e.preventDefault();
              sizeModal.style.display = 'none';
              sizeModal.setAttribute('aria-hidden', 'true');
              document.body.style.overflow = '';
            };

            modalClose.addEventListener('click', closeSizeModal);
            modalOverlay.addEventListener('click', closeSizeModal);
            
            document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && sizeModal.style.display !== 'none') closeSizeModal();
            });

            sizeTriggers.forEach(trigger => {
              trigger.addEventListener('click', (e) => {
                e.preventDefault();
                console.log('Size guide trigger clicked');
                
                const descrTable = document.querySelector('.product-description table, .product-description-card__content table');
                console.log('Table found:', descrTable);
                
                if (descrTable) {
                  modalBody.innerHTML = '';
                  const clonedTable = descrTable.cloneNode(true);
                  
                  // Strip all inline styles and classes to force uniform styling
                  clonedTable.removeAttribute('style');
                  clonedTable.removeAttribute('class');
                  clonedTable.removeAttribute('bgcolor');
                  clonedTable.removeAttribute('border');
                  
                  clonedTable.querySelectorAll('*').forEach(el => {
                    el.removeAttribute('style');
                    el.removeAttribute('class');
                    el.removeAttribute('bgcolor');
                    el.removeAttribute('border');
                    el.removeAttribute('color');
                    if (el.tagName === 'FONT') {
                      el.removeAttribute('face');
                      el.removeAttribute('size');
                    }
                  });
                  
                  modalBody.appendChild(clonedTable);
                  
                  sizeModal.style.display = 'flex';
                  sizeModal.setAttribute('aria-hidden', 'false');
                  document.body.style.overflow = 'hidden';
                } else {
                  const descBlock = document.querySelector('.product-description');
                  if (descBlock) descBlock.scrollIntoView({ behavior: 'smooth' });
                }
              });
            });
          }
        });
      </script>

      <!-- DEBUG VARIANT STOCK LEVELS:
      {% for v in product.variants %}
        - {{ v.title }}: id={{ v.id }} | available={{ v.available }} | qty={{ v.inventory_quantity }} | option1={{ v.option1 }} | option2={{ v.option2 }}
      {% endfor %}
      -->

    </div>
  </div>


  <!-- Detailed Luxury Info Section below the fold -->
  <div class="product-page__info-section">
    <div class="product-page__info-header">
      <span class="product-page__eyebrow" data-i18n="prod_details_eye">Detalhes do Produto</span>
      <h2 class="info-section-title" data-i18n="prod_details_title">Descricao do Produto</h2>
      <p data-i18n="prod_details_sub">Construido para acompanhar o ritmo do dia a dia com presenca, conforto e acabamento premium.</p>
    </div>

    <div class="product-page__info-grid">
      <div class="product-page__info-main">

        {% if product.description != blank %}
          {% assign story_title_top = '' %}
          {% assign story_text_top = '' %}
          {% assign story_title_bottom = '' %}
          {% assign story_text_bottom = '' %}
          {% capture specs_html %}{% endcapture %}

          {% assign description_parts = product.description | split: '</p>' %}
          {% for part in description_parts %}
            {% assign part_text = part | strip_html | strip %}
            {% if part_text != blank %}
              {% if part_text contains 'Título cima:' %}
                {% assign story_title_top = part_text | split: 'Título cima:' | last | strip %}
              {% elsif part_text contains 'Titulo cima:' %}
                {% assign story_title_top = part_text | split: 'Titulo cima:' | last | strip %}
              {% elsif part_text contains 'Título baixo:' %}
                {% assign story_title_bottom = part_text | split: 'Título baixo:' | last | strip %}
              {% elsif part_text contains 'Titulo baixo:' %}
                {% assign story_title_bottom = part_text | split: 'Titulo baixo:' | last | strip %}
              {% elsif part_text contains 'Texto cima:' %}
                {% assign story_text_top = part_text | split: 'Texto cima:' | last | strip %}
              {% elsif part_text contains 'Texto baixo:' %}
                {% assign story_text_bottom = part_text | split: 'Texto baixo:' | last | strip %}
              {% elsif part_text contains 'TextoCriado' %}
                {% assign story_text_top = part_text | remove_first: 'Texto' | strip %}
              {% elsif part_text contains 'Texto O' and story_title_bottom != blank %}
                {% assign story_text_bottom = part_text | remove_first: 'Texto' | strip %}
              {% elsif part_text contains 'Texto' and story_text_top == blank %}
                {% assign story_text_top = part_text | remove_first: 'Texto' | strip %}
              {% elsif part_text contains 'Texto' and story_text_bottom == blank %}
                {% assign story_text_bottom = part_text | remove_first: 'Texto' | strip %}
              {% else %}
                {% capture specs_html %}{{ specs_html }}{{ part }}</p>{% endcapture %}
              {% endif %}
            {% endif %}
          {% endfor %}

          {% assign has_story = false %}
          {% if story_title_top != blank or story_text_top != blank or story_title_bottom != blank or story_text_bottom != blank %}
            {% assign has_story = true %}
          {% endif %}

          {% if has_story %}
            <div class="product-story">
              <article class="product-story__row fade-in">
                <div class="product-story__media">
                  {% if product.images[1] != blank %}
                    <img src="{{ product.images[1] | img_url: '1100x' }}" alt="{{ product.title | escape }} em detalhe" loading="lazy">
                  {% elsif product.featured_image != blank %}
                    <img src="{{ product.featured_image | img_url: '1100x' }}" alt="{{ product.title | escape }} em detalhe" loading="lazy">
                  {% endif %}
                </div>
                <div class="product-story__content">
                  <span class="product-story__kicker" data-i18n="prod_details_feat">Destaque</span>
                  {% if story_title_top != blank %}
                    <h3>{{ story_title_top }}</h3>
                  {% endif %}
                  {% if story_text_top != blank %}
                    <p>{{ story_text_top }}</p>
                  {% endif %}
                </div>
              </article>

              <article class="product-story__row product-story__row--reverse fade-in">
                <div class="product-story__media">
                  {% if product.images[2] != blank %}
                    <img src="{{ product.images[2] | img_url: '1100x' }}" alt="{{ product.title | escape }} em uso" loading="lazy">
                  {% elsif product.featured_image != blank %}
                    <img src="{{ product.featured_image | img_url: '1100x' }}" alt="{{ product.title | escape }} em uso" loading="lazy">
                  {% endif %}
                </div>
                <div class="product-story__content">
                  <span class="product-story__kicker" data-i18n="prod_details_det">Detalhe</span>
                  {% if story_title_bottom != blank %}
                    <h3>{{ story_title_bottom }}</h3>
                  {% endif %}
                  {% if story_text_bottom != blank %}
                    <p>{{ story_text_bottom }}</p>
                  {% endif %}
                </div>
              </article>
            </div>
          {% endif %}

          {% if specs_html != blank or has_story == false %}
          <div class="product-description-card{% unless has_story %} product-description-card--standalone{% endunless %} fade-in">
            <div class="product-description-card__media">
              {% if product.images[3] != blank %}
                <img src="{{ product.images[3] | img_url: '1100x' }}" alt="{{ product.title | escape }} caracteristicas" loading="lazy">
              {% elsif product.images[2] != blank %}
                <img src="{{ product.images[2] | img_url: '1100x' }}" alt="{{ product.title | escape }} caracteristicas" loading="lazy">
              {% elsif product.featured_image != blank %}
                <img src="{{ product.featured_image | img_url: '1100x' }}" alt="{{ product.title | escape }} caracteristicas" loading="lazy">
              {% endif %}
            </div>
            <div class="product-description-card__content">
              <span class="product-story__kicker" data-i18n="prod_details_spec">Especificacoes</span>
              <h3 data-i18n="prod_details_full">Caracteristicas completas</h3>
              <div class="product-description">
                {% if specs_html != blank %}
                  {{ specs_html }}
                {% else %}
                  {{ product.description }}
                {% endif %}
              </div>
            </div>
          </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Product Reviews Section -->
  <div class="product-page__reviews-wrapper" style="margin-top: 60px; max-width: 1200px; margin-left: auto; margin-right: auto; padding: 0 15px;">
    <div class="editorial-reviews" id="productReviews" data-product-id="{{ product.id }}">
      <div class="editorial-reviews__header" style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
        <div>
          <h2 style="margin: 0; font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 500; color: var(--color-gold);" data-i18n="rev_product">Avaliações do Produto</h2>
        </div>
        <div class="editorial-reviews__actions">
          {% if customer %}
            <button class="btn btn--secondary btn--small" onclick="document.getElementById('productReviewFormWrapper').style.display = 'block'; this.style.display='none'" data-i18n="rev_leave">Deixar uma Avaliação</button>
          {% else %}
            <a href="/account/login" class="btn btn--secondary btn--small" style="text-decoration: none;" data-i18n="rev_login">Iniciar Sessão para Avaliar</a>
          {% endif %}
        </div>
      </div>

      <div class="editorial-reviews__form-wrapper" id="productReviewFormWrapper" style="display: none; margin-bottom: 40px; background: rgba(255,255,255,0.02); padding: 30px; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
        <form id="productReviewForm" class="editorial-reviews__form">
          <input type="hidden" id="productReviewName" value="{{ customer.first_name }} {{ customer.last_name }}">
          <input type="hidden" id="productReviewCustomerId" value="{{ customer.id }}">
          <p style="color: #fff; font-size: 14px; margin-bottom: 0px; opacity: 0.8;"><span data-i18n="rev_rating_as">A avaliar publicamente como:</span> <strong>{{ customer.first_name }} {{ customer.last_name }}</strong></p>
          <div class="editorial-reviews__stars-input" style="margin: 15px 0;">
            <input type="hidden" id="productReviewStars" value="5">
            <div class="star-rating-widget" id="productStarRatingWidget">
              <span data-value="1" class="active">★</span>
              <span data-value="2" class="active">★</span>
              <span data-value="3" class="active">★</span>
              <span data-value="4" class="active">★</span>
              <span data-value="5" class="active">★</span>
            </div>
          </div>
          <textarea id="productReviewComment" placeholder="A sua opinião sobre este artigo..." required rows="3" style="width: 100%; background: transparent; border: 1px solid rgba(255,255,255,0.2); color: #fff; padding: 15px; border-radius: 4px; font-family: inherit; margin-bottom: 15px;" data-i18n-placeholder="rev_placeholder"></textarea>
          <button type="submit" class="btn btn--secondary btn--small" style="width: 100%;" data-i18n="rev_submit">Enviar Avaliação</button>
        </form>
      </div>

      <div class="editorial-reviews__list" id="productReviewsList" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        <!-- Product Reviews injected via JS -->
      </div>

      <div class="editorial-reviews__pagination" id="productReviewsPagination" style="margin-top: 30px; text-align: center;">
        <!-- Pagination injected via JS -->
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"Product page",
  "settings":[],
  "blocks":[],
  "presets":[{"name":"Product"}]
}
{% endschema %}
