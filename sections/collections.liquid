<section class="collections container" aria-label="Colecções">
  <h2 class="section-title">Coleções</h2>
  <div class="collections__grid">
    <a class="collection-card" href="/collections/nova-colecao">
      <img src="/images/collection-new.jpg" alt="Nova Coleção" loading="lazy">
      <div class="collection-card__meta"><h3>Nova Coleção</h3><span class="btn btn--ghost">Explorar</span></div>
    </a>
    <a class="collection-card" href="/collections/vestidos">
      <img src="/images/collection-dresses.jpg" alt="Vestidos" loading="lazy">
      <div class="collection-card__meta"><h3>Vestidos</h3><span class="btn btn--ghost">Explorar</span></div>
    </a>
    <a class="collection-card" href="/collections/casacos">
      <img src="/images/collection-coats.jpg" alt="Casacos" loading="lazy">
      <div class="collection-card__meta"><h3>Casacos</h3><span class="btn btn--ghost">Explorar</span></div>
    </a>
    <a class="collection-card" href="/collections/tops">
      <img src="/images/collection-tops.jpg" alt="Tops" loading="lazy">
      <div class="collection-card__meta"><h3>Tops</h3><span class="btn btn--ghost">Explorar</span></div>
    </a>
    <a class="collection-card" href="/collections/calcas">
      <img src="/images/collection-pants.jpg" alt="Calças" loading="lazy">
      <div class="collection-card__meta"><h3>Calças</h3><span class="btn btn--ghost">Explorar</span></div>
    </a>
    <a class="collection-card" href="/collections/acessorios">
      <img src="/images/collection-accessories.jpg" alt="Acessórios" loading="lazy">
      <div class="collection-card__meta"><h3>Acessórios</h3><span class="btn btn--ghost">Explorar</span></div>
    </a>
  </div>
</section>

{% schema %}
{
  "name":"Collections",
  "settings":[],
  "presets":[{"name":"Collections"}]
}
{% endschema %}
