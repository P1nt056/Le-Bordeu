<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ page_title }} - Le Bordeu</title>
    <link rel="stylesheet" href="{{ 'styles.css' | asset_url }}">
    {{ content_for_header }}
  </head>
  <body class="theme-le-bordeu">
    {% include 'header' %}

    <main role="main">{{ content_for_layout }}</main>

    {% include 'footer' %}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.3/dist/css/splide.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.3/dist/js/splide.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/medium-zoom@1.0.6/dist/medium-zoom.min.js" defer></script>
    <script src="{{ 'product.js' | asset_url }}" defer></script>
    {{ content_for_footer }}
  </body>
</html>
